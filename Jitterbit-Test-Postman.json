                        "method": "POST",
                        "url": {
                            "raw": "{{baseUrl}}/api/order",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "order"
                            ]
                        },
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Accept",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"numeroPedido\": \"PED-2024-001\",\n  \"valorTotal\": 150.00,\n  \"dataCriacao\": \"2024-01-15T10:30:00Z\",\n  \"items\": [\n    {\n      \"idItem\": \"1\",\n      \"quantidadeItem\": 2,\n      \"valorItem\": 50.00\n    },\n    {\n      \"idItem\": \"2\",\n      \"quantidadeItem\": 1,\n      \"valorItem\": 50.00\n    }\n  ]\n}"
