{
    "info": {
        "name": "Jitterbit Test API",
        "description": "Collection for testing the Order API deployed on Render",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "baseUrl",
            "value": "https://jitterbit-test.onrender.com",
            "type": "string"
        }
    ],
    "item": [
        {
            "name": "Health Check",
            "request": {
                "method": "GET",
                "url": {
                    "raw": "{{baseUrl}}/",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        ""
                    ]
                },
                "header": [
                    {
                        "key": "Accept",
                        "value": "application/json"
                    }
                ]
            }
        },
        {
