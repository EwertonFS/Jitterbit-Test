# Este arquivo contém requisições HTTP para testar a API de Pedidos
# Use a extensão "REST Client" do VS Code para executar estas requisições
# ==============================================================================

# ==============================================================================
# CONFIGURAÇÕES GLOBAIS
# ==============================================================================
@baseUrl = http://localhost:3000
@contentType = application/json
@orderId =PED-2024-001

# ==============================================================================
# CABEÇALHOS PADRÃO
# ==============================================================================
# Estes headers serão usados em todas as requisições
@accept = application/json
@cache-control = no-cache




### Teste - Listar todas as rotas disponíveis
GET {{baseUrl}}/
Accept: {{accept}}
Cache-Control: {{cache-control}}


### Teste - Criar Pedido
POST {{baseUrl}}/api/order
Content-Type: {{contentType}}
Accept: {{accept}}

{
  "numeroPedido": "PED-2024-002",
  "valorTotal": 150.00,
  "dataCriacao": "2024-01-15T10:30:00Z",
  "items": [
    {
      "idItem": "1",
      "quantidadeItem": 2,
      "valorItem": 50.00
    },
    {
      "idItem": "2",
      "quantidadeItem": 1,
      "valorItem": 50.00
    }
  ]
}

SEÇÃO 3: CONSULTA DE PEDIDOS
# ==============================================================================
###

# @name listAllOrders
# @description Lista todos os pedidos cadastrados
# @response Success: Returns array of orders
GET {{baseUrl}}/api/order
Accept: {{accept}}
Cache-Control: {{cache-control}}

###

# @name getOrderById
# @description Busca um pedido específico pelo ID
# @param orderId - ID do pedido a ser buscado
GET {{baseUrl}}/api/order/{{orderId}}
Accept: {{accept}}

###

# @name getOrderById_NotFound
# @description Testa cenário de pedido não encontrado (edge case)
GET {{baseUrl}}/api/order/999999
Accept: {{accept}}

# ==============================================================================
# SEÇÃO 4: ATUALIZAÇÃO DE PEDIDOS
# ==============================================================================
####
# @name updateOrder
# @description Atualiza um pedido existente
# @param orderId - ID do pedido a ser atualizado
PUT {{baseUrl}}/api/order/{{orderId}}
Content-Type: {{contentType}}
Accept: {{accept}}

{
    "numeroPedido": "PED-2026-001-UPDATED",
    "valorTotal": 200.00,
    "dataCriacao": "2026-03-08T12:00:00Z",
    "items": [
        {
            "idItem": 1,
            "quantidadeItem": 3,
            "valorItem": 50.00
        },
        {
            "idItem": 3,
            "quantidadeItem": 1,
            "valorItem": 50.00
        }
    ]
}

###

# @name updateOrder_NotFound
# @description Testa cenário de atualização de pedido inexistente (edge case)
PUT {{baseUrl}}/api/order/999999
Content-Type: {{contentType}}
Accept: {{accept}}

{
    "numeroPedido": "PED-TEST",
    "valorTotal": 100.00,
    "dataCriacao": "2026-03-08T10:00:00Z",
    "items": []
}

###

# @name updateOrder_ValidationError
# @description Testa cenário de validação com dados inválidos (edge case)
PUT {{baseUrl}}/api/order/{{orderId}}
Content-Type: {{contentType}}
Accept: {{accept}}

{
    "numeroPedido": "",
    "valorTotal": -50.00,
    "dataCriacao": "invalid-date",
    "items": []
}

# ==============================================================================
# SEÇÃO 5: EXCLUSÃO DE PEDIDOS
# ==============================================================================
###

# @name deleteOrder
# @description Deleta um pedido existente
# @param orderId - ID do pedido a ser deletado
DELETE {{baseUrl}}/api/order/{{orderId}}
Accept: {{accept}}

###

# @name deleteOrder_NotFound
# @description Testa cenário de exclusão de pedido inexistente (edge case)
DELETE {{baseUrl}}/api/order/999999
Accept: {{accept}}

